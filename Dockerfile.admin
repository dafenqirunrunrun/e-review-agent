FROM node:20-bookworm-slim AS build

WORKDIR /app
COPY litemall-admin/package.json litemall-admin/package-lock.json ./
RUN npm ci
COPY litemall-admin ./
ENV NODE_ENV=production \
    VUE_APP_BASE_API=/admin
RUN npm run build:prod

FROM nginx:1.29.0-alpine3.22
COPY docker/nginx-admin.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 8081
HEALTHCHECK --interval=20s --timeout=5s --retries=5 CMD wget -qO- http://127.0.0.1:8081/ >/dev/null || exit 1
