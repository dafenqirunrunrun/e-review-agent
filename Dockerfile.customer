FROM node:20-bookworm-slim AS build

WORKDIR /app
COPY litemall-vue/package.json litemall-vue/package-lock.json ./
RUN npm ci
COPY litemall-vue ./
ENV NODE_ENV=production \
    VUE_APP_BASE_API=/wx
RUN npm run build:prod

FROM nginx:1.29.0-alpine3.22
COPY docker/nginx-customer.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 8082
HEALTHCHECK --interval=20s --timeout=5s --retries=5 CMD wget -qO- http://127.0.0.1:8082/ >/dev/null || exit 1
