# Select qwen, deepseek, or local_rule_fallback. Keep secrets in a local environment only.
E_REVIEW_LLM_PROVIDER=local_rule_fallback
E_REVIEW_LLM_TIMEOUT_SECONDS=30
E_REVIEW_LLM_MAX_RETRIES=2

E_REVIEW_QWEN_ENABLED=true
E_REVIEW_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
E_REVIEW_QWEN_MODEL=qwen-plus
E_REVIEW_QWEN_API_KEY=

E_REVIEW_DEEPSEEK_ENABLED=true
E_REVIEW_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
E_REVIEW_DEEPSEEK_MODEL=deepseek-chat
E_REVIEW_DEEPSEEK_API_KEY=

# Optional local Qwen3 provider. Keep model weights outside the Git repository.
E_REVIEW_LOCAL_QWEN_ENABLED=true
E_REVIEW_LOCAL_QWEN_MODEL=Qwen/Qwen3-1.7B
E_REVIEW_LOCAL_QWEN_MODEL_DIR=
E_REVIEW_LOCAL_QWEN_DEVICE=auto
E_REVIEW_LOCAL_QWEN_TORCH_DTYPE=auto
E_REVIEW_LOCAL_QWEN_MAX_NEW_TOKENS=512
E_REVIEW_LOCAL_QWEN_ENABLE_THINKING=false
E_REVIEW_LOCAL_QWEN_TIMEOUT_SECONDS=120

# Optional local vLLM/SGLang/LM Studio OpenAI-compatible endpoint.
E_REVIEW_LOCAL_QWEN_BASE_URL=http://127.0.0.1:8009/v1
E_REVIEW_LOCAL_QWEN_MODEL_NAME=Qwen/Qwen3-1.7B

# v1.6 Hybrid RAG. Model weights and FAISS build dependencies remain local.
E_REVIEW_RAG_V2_ENABLED=false
E_REVIEW_RAG_V2_STRATEGY=hybrid_rerank
E_REVIEW_RAG_TOP_K=5
E_REVIEW_RAG_CANDIDATE_K=20
E_REVIEW_RAG_ALPHA=0.30
E_REVIEW_RAG_BETA=0.40
E_REVIEW_RAG_GAMMA=0.20
E_REVIEW_RAG_DELTA=0.10

E_REVIEW_EMBEDDING_PROVIDER=bge_m3
E_REVIEW_BGE_M3_MODEL_DIR=
E_REVIEW_EMBEDDING_DEVICE=cuda
E_REVIEW_EMBEDDING_BATCH_SIZE=16
E_REVIEW_EMBEDDING_NORMALIZE=true
E_REVIEW_EMBEDDING_MAX_LENGTH=512

E_REVIEW_RERANKER_PROVIDER=neural
E_REVIEW_RERANKER_MODEL=BAAI/bge-reranker-base
E_REVIEW_RERANKER_MODEL_DIR=
E_REVIEW_RERANKER_DEVICE=cuda
E_REVIEW_RERANKER_BATCH_SIZE=8

# v1.6.1 local VLM provider. Keep VLM weights and real images outside Git.
E_REVIEW_VLM_PROVIDER=local_qwen3_vl_transformers
E_REVIEW_VLM_MODEL_DIR=./models/Qwen3-VL-2B-Instruct
E_REVIEW_VLM_DEVICE=cuda
E_REVIEW_VLM_DTYPE=auto
E_REVIEW_VLM_LOAD_IN_4BIT=true
E_REVIEW_VLM_MAX_NEW_TOKENS=512
E_REVIEW_VLM_MAX_IMAGES=4
E_REVIEW_VLM_MAX_PIXELS=1048576
E_REVIEW_VLM_TIMEOUT_SECONDS=180
E_REVIEW_VLM_ENABLE_THINKING=false
E_REVIEW_VLM_MEMORY_STRATEGY=serial_lazy_load
