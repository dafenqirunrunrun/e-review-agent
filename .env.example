# E-Review Agent final delivery environment example.
# Copy values into your local shell or service manager as needed.

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=litemall
MYSQL_USER=litemall
MYSQL_PASSWORD=change-me

# Service ports
AI_SERVICE_PORT=8008
WX_API_PORT=8080
ADMIN_API_PORT=8083
LITEMALL_VUE_PORT=6255
LITEMALL_ADMIN_PORT=9527

# AI Agent framework
AGENT_FRAMEWORK_ENABLED=true
AGENT_FRAMEWORK_PROVIDER=langgraph
AGENT_FRAMEWORK_FALLBACK_ENABLED=true
AGENT_FRAMEWORK_REQUIRE_API_KEY=false

# Optional only. Leave empty for rule/mock tool execution.
OPENAI_API_KEY=
